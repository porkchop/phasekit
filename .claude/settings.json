{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(node --version)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(pnpm install)",
      "Bash(npm run lint *)",
      "Bash(pnpm run lint *)",
      "Bash(npm run test *)",
      "Bash(pnpm run test *)",
      "Bash(npm run build *)",
      "Bash(pnpm run build *)",
      "Bash(npx playwright *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git tag *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/deny-dangerous-commands.sh"
          }
        ]
      }
    ]
  }
}
